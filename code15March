/* ========================= VOLUME UI ========================= */
void drawVolumeUI(int pct) {
  tft.fillScreen(TFT_BLACK);

  // ── Outer decorative rings ──
  tft.drawCircle(120,120,112, tft.color565(20,40,60));
  tft.drawCircle(120,120,111, tft.color565(10,20,40));
  tft.drawCircle(120,120,108, tft.color565(30,60,90));

  // ── Arc bar: full circle sweep -210° to 30° (240° total) ──
  const int steps = 180;
  int filled = (int)(steps * pct / 100.0f);
  const int r1=82, r2=104;
  for (int i=0; i<steps; i++) {
    float t0=(float)i/steps, t1=(float)(i+1)/steps;
    float a0=d2r(mapf(t0,0,1,TSTART,TEND));
    float a1=d2r(mapf(t1,0,1,TSTART,TEND));
    int x00=CX+cosf(a0)*r1, y00=CY+sinf(a0)*r1;
    int x01=CX+cosf(a1)*r1, y01=CY+sinf(a1)*r1;
    int x10=CX+cosf(a0)*r2, y10=CY+sinf(a0)*r2;
    int x11=CX+cosf(a1)*r2, y11=CY+sinf(a1)*r2;
    uint16_t col;
    if (i < filled) {
      float mix = (float)i / (steps-1);
      if (pct >= 100) {
        // Full: bright white-blue flash
        col = rgb565(180, 220, 255);
      } else {
        // Gradient: deep blue → cyan → bright aqua
        col = rgb565(
          (uint8_t)(20  + (int)(60*mix)),
          (uint8_t)(120 + (int)(135*mix)),
          (uint8_t)(255 - (int)(30*mix))
        );
      }
    } else {
      // Unfilled: very dark blue-grey
      col = rgb565(12, 20, 35);
    }
    tft.fillTriangle(x00,y00,x01,y01,x11,y11,col);
    tft.fillTriangle(x00,y00,x10,y10,x11,y11,col);
  }

  // ── Tick marks at 0, 25, 50, 75, 100% ──
  for (int t=0; t<=100; t+=25) {
    float ang = d2r(mapf((float)t/100.0f, 0,1, TSTART, TEND));
    bool major = (t%25==0);
    int rInner = r2+2, rOuter = r2 + (major ? 10 : 6);
    uint16_t tc = (t <= pct) ? rgb565(100,200,255) : rgb565(40,60,80);
    tft.drawLine(CX+cosf(ang)*rInner, CY+sinf(ang)*rInner,
                 CX+cosf(ang)*rOuter, CY+sinf(ang)*rOuter, tc);
  }

  // ── Centre fill ──
  tft.fillCircle(120,120,78, rgb565(5,10,18));

  // ── Speaker icon (simple — three arcs) ──
  tft.fillRect(105,102,8,16,rgb565(60,120,180));          // speaker body
  tft.fillTriangle(113,97, 113,123, 122,128, rgb565(60,120,180));  // cone
  // volume arcs
  if(pct > 0)  tft.drawCircle(124,110,8,  rgb565(80,160,220));
  if(pct > 30) tft.drawCircle(124,110,13, rgb565(60,130,200));
  if(pct > 60) tft.drawCircle(124,110,18, rgb565(40,100,180));

  // ── Percentage text ──
  tft.fillRect(55,130,130,30,rgb565(5,10,18));
  if (pct >= 100) {
    tft.setTextColor(rgb565(255,80,80), rgb565(5,10,18));
    tft.drawCentreString("MAX", 120, 135, 4);
  } else {
    tft.setTextColor(rgb565(180,230,255), rgb565(5,10,18));
    tft.drawCentreString(String(pct)+"%", 120, 135, 4);
  }

  // ── MIN / MAX labels at arc ends ──
  tft.setTextColor(rgb565(40,70,100), TFT_BLACK);
  tft.drawCentreString("0",   36, 176, 1);
  tft.drawCentreString("100",200, 176, 1);

  // ── Footer ──
  tft.setTextColor(rgb565(30,50,70), TFT_BLACK);
  tft.drawCentreString("Press = back", 120, 195, 1);
}

