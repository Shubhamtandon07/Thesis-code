/* ========================= MAIN LOOP ========================= */
void loop(){
  // ── Serial commands ──
  checkSerialCommands();

  // ── Detent / rotation events ──
  if(g_detent_changed){
    g_detent_changed=false;
    int idx = g_detent_index;

    if(g_app_state == STATE_MENU){
      // Toggle cursor between 2 options
      g_menu_cursor = (idx % 2 == 0) ? MENU_UI : MENU_VOLUME;
      drawMainMenu();
      Serial.print("MENU cursor: "); Serial.println(g_menu_cursor==MENU_UI?"UI":"VOLUME");

    } else if(g_app_state == STATE_UI){
      // Cycle 3 UI modes
      switchUIMode((UIMode)(idx % 3));

    } else if(g_app_state == STATE_VOLUME){
      // Volume updated by haptic task, just reflect it on screen + LEDs
      g_volume = constrain(idx, 0, 100);
      if(g_volume != g_old_volume){
        drawVolumeUI(g_volume);
        setLEDsBrightness(g_volume);
        g_old_volume = g_volume;
        Serial.print("VOLUME: "); Serial.println(g_volume);
      }
    }
  }

  // ── Timed UI updates (only in UI sub-states) ──
  if(millis() >= updateTime){
    updateTime = millis() + LOOP_PERIOD;
    if(g_app_state == STATE_UI){
      if(g_ui_mode==MODE_SPEEDO){
        if(speed!=old_speed){updateNeedle(speed);displaySpeed(speed);old_speed=speed;}
        if(gear !=old_gear) {displayGear(gear);  old_gear=gear;}
      } else if(g_ui_mode==MODE_TORQUE){
        if(fabsf(torqueNm-oldTorqueNm)>0.02f){torque_drawDynamic();oldTorqueNm=torqueNm;}
      } else {
        if(rpm!=old_rpm){rpm_drawDynamic();old_rpm=rpm;}
      }
    }
  }

  // ── Press detection via HX711 ──
  long raw_value=readHX711();
  total-=readings[readIndex];
  readings[readIndex]=raw_value;
  total+=readings[readIndex];
  readIndex=(readIndex+1)%numReadings;
  average=total/numReadings;
  long strain_diff=labs(average-strain_zero_value)*sensitivity_factor;

  bool pressed=(strain_diff > strain_threshold);
  if(pressed && !ledWasRed){
    onPress();  // handles all state transitions
  }
  if(!pressed){
    // restore idle LED colour based on state
    if(g_app_state==STATE_VOLUME){
      setLEDsBrightness(g_volume);
    } else {
      setAllLEDs(leds.Color(0,30,0));
    }
  }
  ledWasRed=pressed;

  // ── Debug ──
  static unsigned long lastDebug=0;
  if(millis()-lastDebug>500){
    lastDebug=millis();
    Serial.print("State:"); Serial.print(g_app_state);
    Serial.print(" Vol:");  Serial.print(g_volume);
    Serial.print(" Spd:");  Serial.print(speed);
    Serial.print(" Tq:");   Serial.print(torqueNm, 1);
    Serial.print(" RPM:");  Serial.print(rpm);
    Serial.print(" Str:");  Serial.println(strain_diff);
  }
}

