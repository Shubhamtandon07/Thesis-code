/* ========================= SETUP ========================= */
void setup(){
  Serial.begin(115200);
  tft.init();
  tft.setRotation(0);
  tft.fillScreen(TFT_BLACK);
  backlightInit();

  leds.begin(); leds.setBrightness(255); leds.clear(); leds.show();

  pinMode(HX711_SCK,OUTPUT); pinMode(HX711_DOUT,INPUT);
  digitalWrite(HX711_SCK,LOW);

  HFX_init();
  calibrateStrainGauge();

  // Start at main menu
  enterMenu();
