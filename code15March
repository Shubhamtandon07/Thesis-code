/* ========================= PRESS HANDLER ========================= */
bool ledWasRed = false;

void onPress() {
  // Flash red LEDs
  setAllLEDs(leds.Color(255,0,0));
  g_haptic_pulse = true;
  delay(120);

  if (g_app_state == STATE_MENU) {
    // Select highlighted menu item
    if (g_menu_cursor == MENU_UI) {
      enterUI();
    } else {
      enterVolume();
    }
  } else {
    // Any sub-state → back to main menu
    enterMenu();
  }
}

/* ========================= STATE TRANSITIONS ========================= */
void enterMenu() {
  g_app_state = STATE_MENU;
  setAllLEDs(leds.Color(0,30,0));
  drawMainMenu();
  Serial.println("STATE: MENU");
}

void enterUI() {
  g_app_state = STATE_UI;
  setAllLEDs(leds.Color(0,30,0));
  switchUIMode(g_ui_mode);  // draw current UI mode
  Serial.println("STATE: UI");
}

void enterVolume() {
  g_app_state = STATE_VOLUME;
  g_volume    = 1;
  g_old_volume = -1;
  setLEDsBrightness(1);
  drawVolumeUI(1);
  Serial.println("STATE: VOLUME");
}

