/* =================================================================
   SYSTEM STATE MACHINE
   ─────────────────────────────────────────────────────────────────
   AppState:
     STATE_MENU        — main menu (2 options: UI / VOLUME)
     STATE_UI          — 3 sub-modes: SPEEDO / TORQUE / RPM
     STATE_VOLUME      — volume control 0–100%

   Navigation:
     Rotate   in MENU    → toggle cursor between UI and VOLUME
     Press    in MENU    → enter selected option (red flash → enter)
     Rotate   in UI      → cycle SPEEDO → TORQUE → RPM
     Press    in UI      → red flash → back to MENU
     Rotate   in VOLUME  → CW raises volume, CCW lowers (hard stop at 100)
                           wraps back to 0 if forced past 100
     Press    in VOLUME  → red flash → back to MENU
   ================================================================= */

enum AppState  : uint8_t { STATE_MENU=0, STATE_UI=1, STATE_VOLUME=2 };
enum UIMode    : uint8_t { MODE_SPEEDO=0, MODE_TORQUE=1, MODE_RPM=2 };
enum MenuCursor: uint8_t { MENU_UI=0, MENU_VOLUME=1 };

volatile AppState   g_app_state   = STATE_MENU;
volatile UIMode     g_ui_mode     = MODE_SPEEDO;
volatile MenuCursor g_menu_cursor = MENU_UI;
volatile int        g_detent_index   = 0;
volatile bool       g_detent_changed = false;
volatile bool       g_haptic_pulse   = false;   // declared early — used by onPress()
volatile bool       g_volume_hardstop = false;
volatile bool       g_volume_sync    = false;  // true when V cmd sets volume externally

