/* ========================= HX711 ========================= */
long readHX711(){
  while(digitalRead(HX711_DOUT)==HIGH);
  noInterrupts();
  long value=0;
  for(int i=0;i<24;i++){
    digitalWrite(HX711_SCK,HIGH);delayMicroseconds(1);
    value=(value<<1)|digitalRead(HX711_DOUT);
    digitalWrite(HX711_SCK,LOW); delayMicroseconds(1);
  }
  digitalWrite(HX711_SCK,HIGH);delayMicroseconds(1);
  digitalWrite(HX711_SCK,LOW);
  interrupts();
  if(value&0x800000) value|=0xFF000000;
  return value;
}

void calibrateStrainGauge(){
  Serial.println("Calibrating strain gauge...");
  long sum=0;
  for(int i=0;i<20;i++){sum+=readHX711();delay(50);}
  strain_zero_value=sum/20; calibrated=true;
  Serial.print("Zero set to: "); Serial.println(strain_zero_value);
}

/* ========================= SERIAL COMMANDS ========================= */
void checkSerialCommands(){
  if(!Serial.available()) return;
  String line=Serial.readStringUntil('\n');
  line.trim();
  if(line.startsWith("S ")){  speed=line.substring(2).toInt(); speed=constrain(speed,0,200);
    if(speed==0) gear=0; else if(speed<=20) gear=1;
    else if(speed<=40) gear=2; else if(speed<=80) gear=3;
    else if(speed<=120) gear=4; else if(speed<=160) gear=5; else gear=6;
  } else if(line.startsWith("Q ")){torqueNm=line.substring(2).toFloat();
  } else if(line.startsWith("R ")){rpm=constrain(line.substring(2).toInt(),0,8000);
  } else if(line.startsWith("V ")){
    g_volume=constrain(line.substring(2).toInt(),1,100);  // min=1 so knob never needs 360° reset
    g_volume_sync=true;   // tell haptic task to sync vol_deg_accum
    if(g_app_state==STATE_VOLUME){drawVolumeUI(g_volume);setLEDsBrightness(g_volume);}
  } else if(line=="MENU")   { enterMenu();
  } else if(line=="UI")     { enterUI();
  } else if(line=="VOLUME") { enterVolume();
  } else if(line=="SPEED")  { enterUI(); switchUIMode(MODE_SPEEDO);
  } else if(line=="TORQUE") { enterUI(); switchUIMode(MODE_TORQUE);
  } else if(line=="RPM")    { enterUI(); switchUIMode(MODE_RPM);
  } else {
    char cmd=line.charAt(0);
    switch(cmd){
      case '+': sensitivity_factor+=0.5; break;
      case '-': sensitivity_factor=(sensitivity_factor>0.5)?sensitivity_factor-0.5:0.5; break;
      case 't': strain_threshold=(strain_threshold>500)?strain_threshold-500:500; break;
      case 'T': strain_threshold+=500; break;
      case 'c': calibrateStrainGauge(); break;
      case 'r': strain_threshold=70000;sensitivity_factor=1.0;peakNm=0; break;
      case 'z': calibrateZero(); break;
      case 'v': g_haptic_pulse=true; break;
      case '0': setBacklight(0);   break;
      case '1': setBacklight(64);  break;
      case '2': setBacklight(128); break;
      case '3': setBacklight(192); break;
      case '4': setBacklight(255); break;
    }
  }
}
